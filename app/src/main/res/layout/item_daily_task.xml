<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="6dp"
    android:gravity="center_vertical"
    android:background="@drawable/row_bottom_border"
    android:divider="@drawable/cell_divider"
    android:showDividers="middle">

    <EditText
        android:id="@+id/edit_task_name"
        android:layout_width="0dp"
        android:layout_weight="2"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:background="@null"
        android:hint="Task name"
        android:inputType="text"
        android:paddingStart="6dp"
        android:paddingEnd="6dp" />

    <TextView
        android:id="@+id/text_status"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="18sp"
        android:text="—" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">
        <EditText
            android:id="@+id/edit_start_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:background="@null"
            android:hint="0000"
            android:inputType="number"
            android:maxLength="4"
            android:gravity="center" />
        <TextView
            android:id="@+id/text_start_meridiem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/teal_accent"
            android:textSize="11sp"
            android:padding="2dp"
            android:text="AM" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">
        <EditText
            android:id="@+id/edit_end_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:background="@null"
            android:hint="0000"
            android:inputType="number"
            android:maxLength="4"
            android:gravity="center" />
        <TextView
            android:id="@+id/text_end_meridiem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/teal_accent"
            android:textSize="11sp"
            android:padding="2dp"
            android:text="AM" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_spent_time"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/teal_accent"
        android:text="" />

    <EditText
        android:id="@+id/edit_remarks"
        android:layout_width="0dp"
        android:layout_weight="2"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:background="@null"
        android:hint="Remarks"
        android:paddingStart="6dp"
        android:paddingEnd="6dp" />

</LinearLayout>
